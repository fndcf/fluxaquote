{
  "info": {
    "name": "FluxaQuote API",
    "description": "Collection completa da API FluxaQuote.\n\n**Setup:**\n1. Configure a variável `baseUrl` (ex: http://localhost:5000/api/v1)\n2. Faça login no app e copie o token JWT do Firebase\n3. Cole na variável `authToken`\n\nTodas as rotas protegidas usam o header `Authorization: Bearer {{authToken}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "clienteId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orcamentoId",
      "value": "",
      "type": "string"
    },
    {
      "key": "servicoId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoriaId",
      "value": "",
      "type": "string"
    },
    {
      "key": "itemServicoId",
      "value": "",
      "type": "string"
    },
    {
      "key": "limitacaoId",
      "value": "",
      "type": "string"
    },
    {
      "key": "palavraChaveId",
      "value": "",
      "type": "string"
    },
    {
      "key": "notificacaoId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar Empresa",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "auth": { "type": "noauth" },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeEmpresa\": \"Minha Empresa\",\n  \"email\": \"admin@empresa.com\",\n  \"telefone\": \"11999999999\",\n  \"senha\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Verificar Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/check-slug/minha-empresa",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Dados do Usuário Logado",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Listar Todos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/clientes"
          }
        },
        {
          "name": "Listar Paginado",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clientes/paginated?page=1&limit=10&busca=",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "paginated"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "busca", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Pesquisar",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clientes/pesquisar?termo=empresa",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "pesquisar"],
              "query": [
                { "key": "termo", "value": "empresa" }
              ]
            }
          }
        },
        {
          "name": "Buscar por Documento",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/clientes/documento/12345678000199"
          }
        },
        {
          "name": "Buscar por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/clientes/{{clienteId}}"
          }
        },
        {
          "name": "Criar Cliente",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/clientes",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razaoSocial\": \"Empresa Teste LTDA\",\n  \"nomeFantasia\": \"Empresa Teste\",\n  \"cnpj\": \"12345678000199\",\n  \"tipoPessoa\": \"juridica\",\n  \"endereco\": \"Rua Teste, 123\",\n  \"cidade\": \"São Paulo\",\n  \"estado\": \"SP\",\n  \"cep\": \"01234-567\",\n  \"telefone\": \"11999999999\",\n  \"email\": \"contato@empresateste.com\"\n}"
            }
          }
        },
        {
          "name": "Atualizar Cliente",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/clientes/{{clienteId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razaoSocial\": \"Empresa Teste Atualizada LTDA\",\n  \"telefone\": \"11988888888\"\n}"
            }
          }
        },
        {
          "name": "Excluir Cliente",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/clientes/{{clienteId}}"
          }
        }
      ]
    },
    {
      "name": "Orçamentos",
