          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orcamentos",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"completo\",\n  \"clienteId\": \"{{clienteId}}\",\n  \"clienteNome\": \"Empresa Teste\",\n  \"clienteCnpj\": \"12345678000199\",\n  \"servicoId\": \"{{servicoId}}\",\n  \"servicoDescricao\": \"Serviço de Teste\",\n  \"status\": \"aberto\",\n  \"dataEmissao\": \"2026-03-21\",\n  \"dataValidade\": \"2026-04-21\",\n  \"condicaoPagamento\": \"a_vista\",\n  \"mostrarValoresDetalhados\": true,\n  \"itensCompleto\": [\n    {\n      \"etapa\": \"comercial\",\n      \"categoriaId\": \"{{categoriaId}}\",\n      \"categoriaNome\": \"Categoria Teste\",\n      \"descricao\": \"Item de teste\",\n      \"unidade\": \"un\",\n      \"quantidade\": 1,\n      \"valorUnitarioMaoDeObra\": 100,\n      \"valorUnitarioMaterial\": 50,\n      \"valorTotalMaoDeObra\": 100,\n      \"valorTotalMaterial\": 50,\n      \"valorTotal\": 150\n    }\n  ],\n  \"valorTotal\": 150,\n  \"valorTotalMaoDeObra\": 100,\n  \"valorTotalMaterial\": 50\n}"
            }
          }
        },
        {
          "name": "Atualizar Orçamento",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/orcamentos/{{orcamentoId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"observacoes\": \"Observação atualizada\",\n  \"valorTotal\": 200\n}"
            }
          }
        },
        {
          "name": "Alterar Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orcamentos/{{orcamentoId}}/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"aceito\"\n}"
            }
          }
        },
        {
          "name": "Duplicar Orçamento",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orcamentos/{{orcamentoId}}/duplicar"
          }
        },
        {
          "name": "Verificar Expirados",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orcamentos/verificar-expirados"
          }
        },
        {
          "name": "Excluir Orçamento",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/orcamentos/{{orcamentoId}}"
          }
        }
      ]
