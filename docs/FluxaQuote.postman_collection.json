            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orcamentos/periodo?dataInicio=2026-01-01&dataFim=2026-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["orcamentos", "periodo"],
              "query": [
                { "key": "dataInicio", "value": "2026-01-01" },
