rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isTenantOwner(tenantId) {
      return isAuthenticated() && request.auth.token.tenantId == tenantId;
    }

    // TENANT - dados do tenant (somente owner)
    match /tenants/{tenantId} {
      allow read: if isTenantOwner(tenantId);
      allow update: if isTenantOwner(tenantId);
      allow create, delete: if false;

      // Subcollections permitidas (somente owner do tenant)
      match /clientes/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /orcamentos/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /servicos/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /categoriasItem/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /itensServico/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /limitacoes/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /palavrasChave/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /notificacoes/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /configuracoes/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /contadores/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /historicoValoresItens/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
      match /historicoConfiguracoes/{docId} {
        allow read, write: if isTenantOwner(tenantId);
      }
    }

    // SLUG LOOKUP - público para leitura (validação no registro)
    match /slugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // USER-TENANT MAPPING - somente próprio UID
    match /userTenants/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false;
    }

    // REGRA PADRAO - NEGAR TUDO
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
