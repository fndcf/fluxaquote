rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isTenantOwner(tenantId) {
      return isAuthenticated() && request.auth.token.tenantId == tenantId;
    }

    // TENANT - dados do tenant (somente owner)
    match /tenants/{tenantId} {
      allow read: if isTenantOwner(tenantId);
      allow update: if isTenantOwner(tenantId);
      allow create, delete: if false;
    }

    // SLUG LOOKUP - público para leitura (validação no registro)
    match /slugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // USER-TENANT MAPPING - somente próprio UID
    match /userTenants/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false;
    }

    // SUBCOLLECTIONS DO TENANT - somente owner do tenant
    match /tenants/{tenantId}/{collection}/{docId} {
      allow read, write: if isTenantOwner(tenantId);
    }

    // SUBCOLLECTIONS ANINHADAS (ex: configuracoes dentro do tenant)
    match /tenants/{tenantId}/{collection}/{docId}/{subcol}/{subdocId} {
      allow read, write: if isTenantOwner(tenantId);
    }

    // REGRA PADRAO - NEGAR TUDO
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
